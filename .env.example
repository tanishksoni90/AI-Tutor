PROJECT_NAME=AI-Tutor
ENV_MODE=dev

# PostgreSQL
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=aitutor
POSTGRES_PORT=5432

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=course_knowledge
USE_QDRANT=true

# =============================================================================
# EMBEDDING CONFIGURATION
# =============================================================================
# Using local E5-large-v2 model (1024 dimensions) for testing
# This runs entirely on your M3 MacBook - no API calls needed for embeddings

USE_LOCAL_EMBEDDINGS=true
LOCAL_EMBEDDING_MODEL=intfloat/e5-large-v2
LOCAL_EMBEDDING_DIM=1024

# Gemini embedding settings (not used when USE_LOCAL_EMBEDDINGS=true)
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIM=1536

# Gemini
GEMINI_API_KEY="your-gemini-api-key-here"

# =============================================================================
# SECURITY (Development defaults - change in production)
# =============================================================================
JWT_SECRET_KEY=dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
PII_SALT=dev-salt-change-in-production